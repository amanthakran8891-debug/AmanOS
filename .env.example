# PostgreSQL connection string (Neon, Supabase, Railway, local Postgres, …)
#
# IMPORTANT for Neon: use the POOLED connection string (host contains "-pooler")
# and keep sslmode=require. The pooler keeps connections alive and prevents the
# dev-server "Error in PostgreSQL connection: Closed" message that happens when
# Neon drops an idle non-pooled connection between hot reloads.
#   postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/amanos?sslmode=require
DATABASE_URL=

# Optional: a direct (non-pooled) URL used only for migrations on serverless DBs.
# If your provider needs it, uncomment in prisma/schema.prisma (directUrl).
# DIRECT_URL=

# ── Single-user auth (private subdomain) ────────────────────────────────────
# The only password that can log in to AmanOS. Set a long, unique value.
AMANOS_PASSWORD=

# Secret used to sign the session cookie (HMAC-SHA256). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# If unset, a known dev fallback is used — DO NOT ship to production without this.
AMANOS_SECRET=
