// AmanOS — Life Command Center
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // If your serverless Postgres needs a separate direct URL for migrations,
  // set DIRECT_URL in .env and uncomment the next line:
  // directUrl = env("DIRECT_URL")
}

/// Single-row settings / targets + recovery anchors.
model Settings {
  id                Int       @id @default(1)
  proteinTarget     Int       @default(140)
  waterTarget       Int       @default(3000) // ml
  sleepTarget       Float     @default(8) // hours
  caloriesTarget    Int       @default(2200)
  stepsTarget       Int       @default(8000)
  nclexHoursTarget  Float     @default(4)
  dailyBudget       Int       @default(1000)
  gymDaysTarget     Int       @default(4) // sessions per week
  noJointGoalDays   Int       @default(90) // clean-streak goal
  weightGoal        Float?
  lastJointAt       DateTime? // anchor for the Hourglass + clean streak
  longestStreakDays Int       @default(0)

  // ── NCLEX / AHPRA Command Center ──
  nclexExamName  String   @default("NCLEX-RN")
  nclexExamDate  DateTime? // exam day → drives the countdown
  nclexDailyQGoal Int     @default(75) // target questions/day

  // ── Recovery profile (relatively static inputs to the estimate engine) ──
  recUseLevel       String  @default("chronic") // light | moderate | heavy | chronic
  recJointsPerDay   Float   @default(3)
  recUseYears       Float   @default(5) // total years of regular use
  recActivityLevel  String  @default("moderate") // sedentary | light | moderate | active
  recExerciseFreq   Int     @default(3) // gym/exercise days per week
  recBaselineWeight Float? // kg — informs fat-stored THC assumption

  // ── Recovery experience (so a relapse never zeroes everything) ──
  recCumulativeCleanDays Int @default(0) // total clean days ever accrued
  recRelapseCount        Int @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

/// One NCLEX study session — drives the question counter, accuracy, and weak-topic analytics.
model NclexSession {
  id        String   @id @default(cuid())
  date      String // "YYYY-MM-DD"
  topic     String // one of the 8 NCLEX-RN Client Need categories
  questions Int      @default(0)
  correct   Int      @default(0)
  minutes   Int      @default(0)
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
  @@index([topic])
}

/// Daily recovery symptom check-in (each field 0–10). Feeds the recovery forecast.
model SymptomLog {
  id           String   @id @default(cuid())
  date         String   @unique // "YYYY-MM-DD"
  cravings     Int      @default(0)
  anxiety      Int      @default(0)
  irritability Int      @default(0)
  sleep        Int      @default(0) // 0 = terrible, 10 = great
  appetite     Int      @default(0)
  motivation   Int      @default(0)
  focus        Int      @default(0)
  mood         Int      @default(0)
  restlessness Int      @default(0)
  boredom      Int      @default(0)
  note         String?
  createdAt    DateTime @default(now())

  @@index([date])
}

/// User reflections per review period (week/month/quarter).
model Review {
  id        String   @id @default(cuid())
  period    String // "week" | "month" | "quarter"
  periodKey String // e.g. "2026-W24", "2026-06", "2026-Q2"
  lesson    String?
  focus     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([period, periodKey])
}

/// One snapshot row per calendar day (date = "YYYY-MM-DD").
model DayLog {
  id             String   @id @default(cuid())
  date           String   @unique
  jointClean     Boolean  @default(true)
  weightKg       Float?
  bodyFat        Float?
  waterMl        Int      @default(0)
  proteinG       Int      @default(0)
  caloriesKcal   Int      @default(0)
  sleepHours     Float    @default(0)
  steps          Int      @default(0)
  nclexHours     Float    @default(0)
  nclexQuestions Int      @default(0)
  nclexCorrect   Int      @default(0)
  bharatfareDone Boolean  @default(false)
  gymDone        Boolean  @default(false)
  spiritualDone  Boolean  @default(false)
  checkinDone    Boolean  @default(false) // used the morning/night check-in
  lifeScore      Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
}

model FoodEntry {
  id        String   @id @default(cuid())
  date      String
  name      String
  proteinG  Int      @default(0)
  calories  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([date])
}

model GymSet {
  id        String   @id @default(cuid())
  date      String
  bodyPart  String
  exercise  String
  sets      Int      @default(0)
  reps      Int      @default(0)
  weightKg  Float    @default(0)
  createdAt DateTime @default(now())

  @@index([date])
  @@index([bodyPart])
}

model Expense {
  id        String   @id @default(cuid())
  date      String
  category  String
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
}

model JointEvent {
  id        String   @id @default(cuid())
  at        DateTime @default(now())
  type      String // "relapse" | "craving"
  craving   String? // "morning" | "afternoon" | "night"
  trigger   String? // "stress" | "boredom" | "loneliness" | "habit" | "celebration"
  intensity Int      @default(0)
  note      String?

  @@index([at])
}

model Achievement {
  id         String   @id @default(cuid())
  key        String   @unique
  unlockedAt DateTime @default(now())
}

// ── Spiritual Command Center ──────────────────────────────────────────────────

/// Single-row "continue reading" position per scripture.
model SpiritualProgress {
  id           Int      @id @default(1)
  gitaChapter  Int      @default(1)
  gitaVerse    Int      @default(1)
  chalisaLine  Int      @default(0) // index into the chalisa text (0 = doha)
  updatedAt    DateTime @updatedAt
}

/// A bookmark or favourite on a verse/line. ref = "2.47" (gita) or "chaupai-12" (chalisa).
model SpiritualMark {
  id        String   @id @default(cuid())
  kind      String // "gita" | "chalisa"
  ref       String
  type      String // "bookmark" | "favourite"
  createdAt DateTime @default(now())

  @@unique([kind, ref, type])
  @@index([kind, type])
}

/// A reflection note attached to a verse/line.
model SpiritualNote {
  id        String   @id @default(cuid())
  kind      String // "gita" | "chalisa"
  ref       String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, ref])
}

/// One reading event per day per scripture — powers streaks + Wisdom XP.
model SpiritualReadingLog {
  id        String   @id @default(cuid())
  date      String // "YYYY-MM-DD"
  kind      String // "gita" | "chalisa" | "reflection"
  count     Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([date, kind])
  @@index([date])
}
